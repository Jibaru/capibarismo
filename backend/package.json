{
  "name": "capibarismo-survey-extractor",
  "version": "1.0.0",
  "description": "Extract and structure survey data from IPSOS PDFs using OpenAI",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [
    "survey",
    "ipsos",
    "pdf",
    "extraction",
    "openai"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@mistralai/mistralai": "^1.14.1",
    "@neondatabase/serverless": "^0.10.1",
    "@scalar/express-api-reference": "^0.8.46",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.37.0",
    "express": "^4.18.2",
    "openai": "^4.28.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.17",
    "@types/pdf-parse": "^1.1.4",
    "drizzle-kit": "^0.29.0",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
